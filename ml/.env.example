# Hệ thống ML - Cấu hình Flask

# Flask
FLASK_PORT=5000
FLASK_DEBUG=True
FLASK_ENV=development

# kagglehub (để tải dataset từ Kaggle)
# Tạo API key tại: https://www.kaggle.com/account
# Tải xuống kaggle.json, đặt vào ~/.kaggle/kaggle.json
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_api_key

# Đường dẫn
DATASET_DIR=./datasets
MODEL_DIR=./models
UPLOAD_DIR=./uploads

# Model
MODEL_NAME=model_cay_cam.h5
IMG_SIZE=224
BATCH_SIZE=32

# Epochs khi train
EPOCHS=10
